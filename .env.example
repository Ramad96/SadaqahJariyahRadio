# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and never committed.

# --- Supabase audio storage ---
# Base URL for the public audio-files bucket in Supabase Storage.
# Format: https://<project-ref>.supabase.co/storage/v1/object/public/audio-files
# Leave blank to fall back to locally bundled audio files.
VITE_SUPABASE_AUDIO_URL=

# --- Upload script only (not used by the app) ---
# Required when running: node scripts/uploadAudioToSupabase.js
# Find these in your Supabase dashboard: Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
